# === LLM Provider ===
# Options: openai, anthropic, google
LLM_PROVIDER=openai

# === LLM Model ===
# Must be one of the models listed in your provider's SUPPORT_MODEL variable below.
LLM_MODEL=gpt-5.4-mini

# === API Keys (set the one matching your provider) ===
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_API_KEY=your-google-key

# === Supported Models per Provider ===
# Comma-separated list of valid model IDs. Used to validate LLM_MODEL before
# making any API call. Edit freely to add new releases without changing source code.
#
# OpenAI models — https://platform.openai.com/docs/models
OPENAI_SUPPORT_MODEL=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano,gpt-4o,gpt-4o-mini,o1,o1-mini,o3,o3-mini,o4-mini
#
# Anthropic models — https://docs.anthropic.com/en/docs/about-claude/models/overview
ANTHROPIC_SUPPORT_MODEL=claude-opus-4-6,claude-sonnet-4-6,claude-haiku-4-5-20251001,claude-haiku-4-5,claude-sonnet-4-5-20250929,claude-sonnet-4-5,claude-opus-4-5-20251101,claude-opus-4-5,claude-opus-4-1-20250805,claude-opus-4-1,claude-sonnet-4-20250514,claude-sonnet-4-0,claude-opus-4-20250514,claude-opus-4-0,claude-3-haiku-20240307
#
# Google Gemini models — https://ai.google.dev/gemini-api/docs/models
GEMINI_SUPPORT_MODEL=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# === Tavily (web search) ===
TAVILY_API_KEY=your-tavily-key

# === Mem0 (long-term memory) ===
MEM0_API_KEY=your-mem0-key

# === User ID (persistent memory identifier) ===
USER_ID=demo_user_2026
